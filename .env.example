# Token do bot — obtido no @BotFather no Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBccDDee...

# Seu Telegram User ID — obtido no @userinfobot
TELEGRAM_ALLOWED_USER_ID=987654321

# Pasta onde arquivos enviados pelo Telegram serão salvos no PC
UPLOAD_DIR=/home/SEU_USUARIO/uploads

# Segundos de espera para capturar output após enviar comando ao tmux
OUTPUT_CAPTURE_DELAY=3
