# Token do bot — obtido no @BotFather no Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHH...

# Seu Telegram User ID — obtido no @userinfobot
TELEGRAM_ALLOWED_USER_ID=987654321

# Segredo TOTP para autenticação 2FA
# Gere em: python3 -c "import pyotp; print(pyotp.random_base32())"
TOTP_SECRET=JBSWY3DPEHPK3PXP

# Caminho para o binário do Claude Code CLI
# Padrão nvm: ~/.nvm/versions/node/vX.X.X/bin/claude
# Ou simplesmente: claude (se estiver no PATH)
CLAUDE_BIN=claude

# Pasta onde arquivos enviados pelo Telegram serão salvos no PC
UPLOAD_DIR=/home/SEU_USUARIO/uploads

# Segundos de espera — não alterar sem necessidade
OUTPUT_CAPTURE_DELAY=3

# Duração da sessão autenticada em segundos (padrão: 8 horas)
AUTH_SESSION_TTL=28800
